# Copy to .env and set your values. Do not commit .env.

# Where /go and /r redirect to (Python server and Vercel both read this).
REDIRECT_TARGET_URL=https://example.com

# Public URL of the redirect endpoint; used when generating the QR image.
# Example: https://your-app.vercel.app/go or https://your-domain.com/go
QR_REDIRECT_BASE_URL=https://example.com/go

# Optional: port for Python redirect server (default 8765).
# QR_REDIRECT_PORT=8765
