# Copy to .env and set your values. Do not commit .env.
# For Vercel, set these in Project Settings → Environment Variables.

# ---- Next.js app (Vercel deploy) ----

# Session encryption (min 32 chars). Generate: openssl rand -base64 32
AUTH_SECRET=

# TOTP secret (base32) for admin login. Generate: npm run totp-setup
TOTP_SECRET=

# Dev only: set to 1 to skip TOTP login during npm run dev
# BYPASS_AUTH=1

# Single fallback for /go (legacy QR codes).
REDIRECT_TARGET_URL=

# Public app URL for QR code content (e.g. https://your-app.vercel.app). Optional; defaults to request origin.
NEXT_PUBLIC_APP_URL=

# ---- MongoDB (required for multiple links and analytics) ----
# Vercel Mongo integration may provide a prefixed URI such as QRCG_MONGODB_URI.
QRCG_MONGODB_URI=
MONGODB_DB=
#
# Optional: if you prefer another prefix, set it and provide <PREFIX>_MONGODB_URI / <PREFIX>_MONGODB_DB.
# MONGODB_ENV_PREFIX=

# ---- Supabase (optional, only for one-time migration script) ----
# If you run `npm run migrate:supabase-to-mongodb`, provide these:
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# Or with a prefix injected by Vercel integration:
# SUPABASE_ENV_PREFIX=QRC

# ---- Python (self-hosted only) ----
# QR_REDIRECT_BASE_URL=https://example.com/go
# QR_REDIRECT_PORT=8765
